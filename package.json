{
  "name": "ackem",
  "version": "1.0.0",
  "private": false,
  "description": "Ackem — local-first AI desktop companion (OpenAI-compatible)",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:win": "set NODE_OPTIONS=--max-old-space-size=8192 && electron-vite dev",
    "build": "set NODE_OPTIONS=--max-old-space-size=8192 && electron-vite build",
    "build:web": "npm run build && node scripts/build-web-server.mjs",
    "web": "node out/web/server.mjs",
    "preview": "electron-vite preview",
    "typecheck": "npm run typecheck:web",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "prepare:embedding-models": "node scripts/download-embedding-models.mjs",
    "build:launcher": "node scripts/build-launcher.mjs",
    "dist:green": "node scripts/build-launcher.mjs && node scripts/build-green-release.mjs",
    "sync:release-doc": "node scripts/sync-release-doc.mjs",
    "sync:green-doc": "node scripts/sync-release-doc.mjs",
    "sync:release-asar": "node scripts/patch-release-asar.mjs",
    "release:asar": "node scripts/patch-release-asar.mjs",
    "patch:release": "node scripts/patch-release-asar.mjs",
    "dist:setup": "npm run build && electron-builder --config electron-builder.yml --win nsis",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "better-sqlite3": "^12.10.0",
    "d3": "^7.9.0",
    "esbuild": "^0.28.0",
    "mineflayer": "^4.37.1",
    "mineflayer-pathfinder": "^2.4.5",
    "opencc-js": "^1.3.1",
    "qrcode": "^1.5.4",
    "ws": "^8.20.1",
    "zustand": "^5.0.0"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "rcedit": "^5.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
